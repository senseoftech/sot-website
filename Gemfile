source "https://rubygems.org"

# This site is published with GitHub Pages, which builds it using the
# `github-pages` gem — a tested, security-patched set of Jekyll
# dependencies. Using the same gem locally keeps `bundle exec jekyll serve`
# in sync with the production build.
#
# To install / update:  bundle install  (or  bundle update github-pages)
gem "github-pages", group: :jekyll_plugins

# Plugins beyond what github-pages bundles go here.
# (jekyll-feed is already included by github-pages and enabled in _config.yml)

# Windows does not include zoneinfo files, so bundle the tzinfo-data gem
# and the wdm gem for faster file watching during local development.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :mswin, :x64_mingw]
